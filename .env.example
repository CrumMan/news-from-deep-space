# Supabase: use Session pooler (port 5432) from Dashboard → Connect → Session.
# Do not use db.<project-ref>.supabase.co locally unless your network supports IPv6.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Optional: keep direct URL and set pooler host to auto-rewrite at runtime
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# SUPABASE_POOLER_HOST=aws-1-<region>.pooler.supabase.com

JWT_SECRET=your-jwt-secret

# Optional: NASA APOD API key (defaults to DEMO_KEY)
NASA_API_KEY=your-nasa-api-key
